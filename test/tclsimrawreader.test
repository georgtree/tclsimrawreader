### Single plot AC binary
test testACBinarySinglePlot-1 {read vectors names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac.raw]]
} -body {
    return [$r names]
} -result {frequency v(ad) v(d) v(g) v(kd) {v(m1#body diode)} v(m1#gate) v(s) i(va) i(vd) i(vg) i(vk) i(vs)} -cleanup {
    $r close
    unset r
}

