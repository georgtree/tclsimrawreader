test testACBinaryMultiPlot-11 {read header from the certain plot, multiplot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac_multiplot.raw]]
} -match glob -body {
    return [$r header -plot 2]
} -result {title {bjt ft test} date {Wed Jul  1 23:27:47  2026} plotname {AC Analysis} nvariables 8 npoints 57\
pointstride 128 flags complex variables {{index 0 name frequency type frequency storage complex128 valuebytes 16\
offsetbytes 0} {index 1 name v(1) type voltage storage complex128 valuebytes 16 offsetbytes 16} {index 2 name v(2) type\
voltage storage complex128 valuebytes 16 offsetbytes 32} {index 3 name v(b) type voltage storage complex128 valuebytes\
16 offsetbytes 48} {index 4 name v(c) type voltage storage complex128 valuebytes 16 offsetbytes 64} {index 5 name i(l)\
type current storage complex128 valuebytes 16 offsetbytes 80} {index 6 name i(vce) type current storage complex128\
valuebytes 16 offsetbytes 96} {index 7 name i(vgain) type current storage complex128 valuebytes 16 offsetbytes 112}}}\
-cleanup {
    $r close
    unset r
}


### Error handling tests
test testErrorHandling-1 {wrong command name} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    catch {$r name} errorStr
    return $errorStr
} -result {unknown raw handle subcommand "name"} -cleanup {
    $r close
    unset r
}

test testErrorHandling-2 {wrong vector name} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    catch {$r vector v(out1)} errorStr
    return $errorStr
} -result {raw vector "v(out1)" not found} -cleanup {
    $r close
    unset r
}

test testErrorHandling-3 {-count option is too large} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    catch {$r vector v(out) -from 0 -count 1000} errorStr
    return $errorStr
} -result {-count extends past end of raw data} -cleanup {
    $r close
    unset r
}

test testErrorHandling-4 {-from option is negative} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    catch {$r vector v(out) -from -1 -count 10} errorStr
    return $errorStr
} -result {range option must be non-negative} -cleanup {
    $r close
    unset r
}

test testErrorHandling-5 {} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac_multiplot.raw]]
} -body {
    catch {$r dict -plot 10} errorStr
    return $errorStr
} -result {plot index 10 out of range} -cleanup {
    $r close
    unset r
}

test testErrorHandling-6 {} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    catch {$r vector v(out) -from 1 -count} errorStr
    return $errorStr
} -result {missing value for option -count} -cleanup {
    $r close
    unset r
}

test testErrorHandling-7 {} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac_multiplot.raw]]
} -body {
    catch {$r dict -plot } errorStr
    return $errorStr
} -result {missing value for option -plot} -cleanup {
    $r close
    unset r
}
