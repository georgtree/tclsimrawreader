package require tcltest
namespace import ::tcltest::*
package require tclsimrawreader
namespace import ::tclsimrawreader::*

configure -verbose start
set currentDir [file normalize [file dirname [info script]]]


### Single plot DC binary
test testDCBinarySinglePlot-1 {read vectors names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r names]
} -result {v(v-sweep) v(in) v(out) i(v1)} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-2 {read number of points names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r npoints]
} -result 51 -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-3 {read all values of selected vector, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r vector v(in)]
} -result {0.0 0.1 0.2 0.30000000000000004 0.4 0.5 0.6 0.7 0.7999999999999999 0.8999999999999999 0.9999999999999999\
1.0999999999999999 1.2 1.3 1.4000000000000001 1.5000000000000002 1.6000000000000003 1.7000000000000004\
1.8000000000000005 1.9000000000000006 2.0000000000000004 2.1000000000000005 2.2000000000000006 2.3000000000000007\
2.400000000000001 2.500000000000001 2.600000000000001 2.700000000000001 2.800000000000001 2.9000000000000012\
3.0000000000000013 3.1000000000000014 3.2000000000000015 3.3000000000000016 3.4000000000000017 3.5000000000000018\
3.600000000000002 3.700000000000002 3.800000000000002 3.900000000000002 4.000000000000002 4.100000000000001\
4.200000000000001 4.300000000000001 4.4 4.5 4.6 4.699999999999999 4.799999999999999 4.899999999999999\
4.999999999999998} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-4 {read range of values of selected vector, single plot binary raw file}\
        -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r vector v(in) -from 0 -count 10]
} -result {0.0 0.1 0.2 0.30000000000000004 0.4 0.5 0.6 0.7 0.7999999999999999 0.8999999999999999} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-5 {read range of values of all vectors, single plot binary raw file}\
        -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r vectors -all -from 0 -count 10]
} -result {v(v-sweep) {0.0 0.1 0.2 0.30000000000000004 0.4 0.5 0.6 0.7 0.7999999999999999 0.8999999999999999} v(in)\
{0.0 0.1 0.2 0.30000000000000004 0.4 0.5 0.6 0.7 0.7999999999999999 0.8999999999999999} v(out) {0.0 0.06666666666666667\
0.13333333333333333 0.2 0.26666666666666666 0.3333333333333333 0.39999999999999997 0.4666666666666666\
0.5333333333333332 0.6} i(v1) {0.0 -3.3333333333333335e-5 -6.666666666666667e-5 -0.00010000000000000002\
-0.00013333333333333334 -0.0001666666666666667 -0.00019999999999999998 -0.00023333333333333339 -0.0002666666666666667\
-0.00030000000000000003}} -cleanup {
    $r close
    unset r
}

