test testDCBinarySinglePlot-7 {read and print header data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r header]
} -match glob -result {title {voltage divider netlist} date * plotname {DC transfer characteristic}\
nvariables 4 npoints 51 pointstride 32 flags real variables {{index 0 name v(v-sweep) type voltage storage real64\
valuebytes 8 offsetbytes 0} {index 1 name v(in) type voltage storage real64 valuebytes 8 offsetbytes 8} {index 2 name\
v(out) type voltage storage real64 valuebytes 8 offsetbytes 16} {index 3 name i(v1) type current storage real64\
valuebytes 8 offsetbytes 24}}} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-8 {read and print plot data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r plots]
} -result {{index 0 kind binary title {voltage divider netlist} plotname {DC transfer characteristic} nvariables 4\
npoints 51 dataoffset 243 databytes 1632}} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-9 {read vectors names, single plot binary raw file with -plot option}\
        -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice dc.raw]]
} -body {
    return [$r names -plot 0]
} -result {v(v-sweep) v(in) v(out) i(v1)} -cleanup {
    $r close
    unset r
}

