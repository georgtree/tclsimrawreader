test testACBinarySinglePlot-7 {read and print header data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac.raw]]
} -body {
    return [$r header]
} -match glob -result {title {capacitance and current comparison between models d and bulk diode in vdmos} date *\
plotname {AC Analysis} nvariables 13 npoints 51 pointstride 208 flags complex variables {{index 0 name frequency type\
frequency storage complex128 valuebytes 16 offsetbytes 0} {index 1 name v(ad) type voltage storage complex128\
valuebytes 16 offsetbytes 16} {index 2 name v(d) type voltage storage complex128 valuebytes 16 offsetbytes 32} {index 3\
name v(g) type voltage storage complex128 valuebytes 16 offsetbytes 48} {index 4 name v(kd) type voltage storage\
complex128 valuebytes 16 offsetbytes 64} {index 5 name v(m1#body type diode) storage complex128 valuebytes 16\
offsetbytes 80} {index 6 name v(m1#gate) type voltage storage complex128 valuebytes 16 offsetbytes 96} {index 7 name\
v(s) type voltage storage complex128 valuebytes 16 offsetbytes 112} {index 8 name i(va) type current storage complex128\
valuebytes 16 offsetbytes 128} {index 9 name i(vd) type current storage complex128 valuebytes 16 offsetbytes 144}\
{index 10 name i(vg) type current storage complex128 valuebytes 16 offsetbytes 160} {index 11 name i(vk) type current\
storage complex128 valuebytes 16 offsetbytes 176} {index 12 name i(vs) type current storage complex128 valuebytes 16\
offsetbytes 192}}} -cleanup {
    $r close
    unset r
}

test testACBinarySinglePlot-8 {read and print plot data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice ac.raw]]
} -body {
    return [$r plots]
} -result {{index 0 kind binary title {capacitance and current comparison between models d and bulk diode in vdmos}\
plotname {AC Analysis} nvariables 13 npoints 51 dataoffset 454 databytes 10608}} -cleanup {
    $r close
    unset r
}

### Single plot Tran binary
test testTranBinarySinglePlot-1 {read vectors names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice tran.raw]]
} -body {
    return [$r names]
} -result {time v(vdd2) v(vdd) v(n2) v(n1) v(n3) v(n4) v(n5) v(n6) v(n7) v(n8) v(n9) v(n10) v(n11) v(n12) v(n13) v(n14)\
v(n15) v(n16) v(osc_out) i(vmeasure) i(vdd)} -cleanup {
    $r close
    unset r
}

test testTranBinarySinglePlot-2 {read number of points names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files ngspice tran.raw]]
} -body {
    return [$r npoints]
} -result 7497 -cleanup {
    $r close
    unset r
}

