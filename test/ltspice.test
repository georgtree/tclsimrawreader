package require tcltest
namespace import ::tcltest::*
package require tclsimrawreader
namespace import ::tclsimrawreader::*

configure -verbose start
set currentDir [file normalize [file dirname [info script]]]
set rawFolder [file join $currentDir raw_files ltspice]

### Single plot DC binary
set filePath [file join $rawFolder dc.raw]
test testDCBinarySinglePlot-1 {read vectors names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw -dialect ltspice $filePath]
} -body {
    return [$r names]
} -result {V1 V(n001) V(n002) I(V1) I(V2) I(cdg:Z1) Ic(Z1) Id(m1:Z1) Ie(Z1) Ig(Z1) Ig(m1:Z1) Is(m1:Z1)} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-2 {read number of points with default plot (first), multiplot binary raw file} -setup {
    set r [tclsimrawreader::openraw -dialect ltspice $filePath]
} -body {
    return [$r npoints]
} -result 51 -cleanup {
    $r close
    unset r
}

