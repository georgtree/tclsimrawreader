test testACBinarySinglePlot-7 {read and print header data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac.raw]]
} -body {
    return [$r header]
} -match glob -result {title {rca3040 ckt - rca 3040 wideband amplifier} date {Sun Jul 05 08:30:01 2026} plotname {AC\
Analysis} nvariables 3 npoints 101 pointstride 48 flags complex variables {{index 0 name FREQUENCY type frequency\
storage complex128 valuebytes 16 offsetbytes 0} {index 1 name V(16) type voltage storage complex128 valuebytes 16\
offsetbytes 16} {index 2 name V(17) type voltage storage complex128 valuebytes 16 offsetbytes 32}}} -cleanup {
    $r close
    unset r
}

test testACBinarySinglePlot-8 {read and print plot data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac.raw]]
} -body {
    return [$r plots]
} -result {{index 0 kind binary title {rca3040 ckt - rca 3040 wideband amplifier} plotname {AC Analysis} nvariables 3\
npoints 101 dataoffset 241 databytes 4848}} -cleanup {
    $r close
    unset r
}

