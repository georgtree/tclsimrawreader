test testDCBinarySinglePlot-7 {read and print header data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder dc.raw]]
} -body {
    return [$r header]
} -match glob -result {title {** NMOSFET: Benchmarking Implementation of BSIM4.6.0 by Mohan V. Dunga 12/13/2006.} date\
{Sun Jul 05 08:26:19 2026} plotname {DC transfer characteristic} nvariables 4 npoints 61 pointstride 32 flags real\
variables {{index 0 name sweep type voltage storage real64 valuebytes 8 offsetbytes 0} {index 1 name V(2) type voltage\
storage real64 valuebytes 8 offsetbytes 8} {index 2 name V(1) type voltage storage real64 valuebytes 8 offsetbytes 16}\
{index 3 name I(VDS) type current storage real64 valuebytes 8 offsetbytes 24}}} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-8 {read and print plot data, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder dc.raw]]
} -body {
    return [$r plots]
} -result {{index 0 kind binary title {** NMOSFET: Benchmarking Implementation of BSIM4.6.0 by Mohan V. Dunga\
12/13/2006.} plotname {DC transfer characteristic} nvariables 4 npoints 61 dataoffset 304 databytes 1952}} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-9 {read range of values of selected vector, single plot binary raw file}\
        -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder dc.raw]]
} -body {
    return [$r vector V(2) -count 10]
} -result {0.0 0.02 0.04 0.06 0.08 0.1 0.12 0.14 0.16 0.18} -cleanup {
    $r close
    unset r
}

test testDCBinarySinglePlot-10 {read range of values of selected vector, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder dc.raw]]
} -body {
    return [$r vector V(2) -from 25]
} -result {0.5 0.52 0.54 0.56 0.58 0.6 0.62 0.64 0.66 0.68 0.7000000000000001 0.72 0.74 0.76 0.78 0.8\
0.8200000000000001 0.84 0.86 0.88 0.9 0.92 0.9400000000000001 0.96 0.98 1.0 1.02 1.04 1.06 1.08 1.1 1.12\
1.1400000000000001 1.16 1.18 1.2} -cleanup {
    $r close
    unset r
}

### Single plot AC binary
test testACBinarySinglePlot-1 {read vectors names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac.raw]]
} -body {
    return [$r names]
} -result {FREQUENCY V(16) V(17)} -cleanup {
    $r close
    unset r
}

test testACBinarySinglePlot-2 {read number of points names, single plot binary raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac.raw]]
} -body {
    return [$r npoints]
} -result 101 -cleanup {
    $r close
    unset r
}

