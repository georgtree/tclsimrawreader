    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac_ascii.raw]]
} -body {
    return [$r names]
} -result {FREQUENCY V(16) V(17)} -cleanup {
    $r close
    unset r
}

test testACAsciiSinglePlot-2 {read number of points names, single plot ascii raw file} -setup {
    set r [tclsimrawreader::openraw [file join $currentDir raw_files $rawFolder ac_ascii.raw]]
} -body {
    return [$r npoints]
} -result 101 -cleanup {
    $r close
    unset r
}

